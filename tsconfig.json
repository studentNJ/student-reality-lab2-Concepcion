{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@student-reality-lab/domain": [
        "packages/domain/src/index.ts"
      ],
      "@student-reality-lab/shared": [
        "packages/shared/src/index.ts"
      ],
      "@student-reality-lab/db": [
        "packages/db/src/index.ts"
      ],
      "@student-reality-lab/mcp-server": [
        "packages/mcp-server/src/index.ts"
      ],
      "@web/*": [
        "apps/web/src/*"
      ]
    },
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "tests/**/*.ts"
  ]
}