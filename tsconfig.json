{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@student-reality-lab/domain": [
        "packages/domain/src/index.ts"
      ],
      "@student-reality-lab/shared": [
        "packages/shared/src/index.ts"
      ],
      "@student-reality-lab/mcp-server": [
        "packages/mcp-server/src/index.ts"
      ]
    },
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "packages/**/*.ts",
    "tests/**/*.ts"
  ]
}