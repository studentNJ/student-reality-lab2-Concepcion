{
  "name": "student-reality-lab2",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck --workspace @student-reality-lab/domain",
    "test": "npm run test:domain",
    "test:domain": "vitest run tests/domain --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}